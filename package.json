{
  "name": "smart-expense-system-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:backend": "npm --prefix SmartExpenseTracker/SmartExpenseTracker/backend run dev",
    "dev:frontend": "npm --prefix SmartExpenseTracker/SmartExpenseTracker/frontend run dev",
    "dev": "npx --yes concurrently --kill-others \"npm run dev:backend\" \"npm run dev:frontend\"",
    "install:all": "npm install --prefix SmartExpenseTracker/SmartExpenseTracker/backend && npm install --prefix SmartExpenseTracker/SmartExpenseTracker/frontend"
  }
}
